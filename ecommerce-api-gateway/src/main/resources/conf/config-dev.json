{
  "http": {
    "port": 8080
  },
  "service": {
    "name": "api-gateway",
    "version": "1.0.0"
  },
  "jwt": {
    "secret": "your-256-bit-secret-key-change-in-production",
    "expirationHours": 24,
    "issuer": "ecommerce-platform"
  },
  "proxy": {
    "timeout": 5000
  },
  "routes": [
    {
      "path": "/api/users/*",
      "serviceName": "user-service",
      "stripPrefix": false,
      "auth": true
    },
    {
      "path": "/api/users/register",
      "serviceName": "user-service",
      "auth": false
    },
    {
      "path": "/api/users/login",
      "serviceName": "user-service",
      "auth": false
    },
    {
      "path": "/api/products/*",
      "serviceName": "product-service",
      "auth": false
    },
    {
      "path": "/api/orders/*",
      "serviceName": "order-service",
      "auth": true
    },
    {
      "path": "/api/inventory/*",
      "serviceName": "inventory-service",
      "auth": true
    },
    {
      "path": "/api/payments/*",
      "serviceName": "payment-service",
      "auth": true
    }
  ],
  "consul": {
    "host": "localhost",
    "port": 8500
  },
  "log": {
    "level": "INFO"
  }
}