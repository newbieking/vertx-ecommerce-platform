{
  "http": {
    "port": 8080
  },
  "service": {
    "name": "api-gateway",
    "version": "1.0.0"
  },
  "jwt": {
    "secret": "your-256-bit-secret-key-change-in-production"
  },
  "routes": [
    {
      "path": "/api/users/*",
      "target": "http://localhost:8081",
      "stripPrefix": false,
      "auth": true
    },
    {
      "path": "/api/users/register",
      "target": "http://localhost:8081",
      "auth": false
    },
    {
      "path": "/api/users/login",
      "target": "http://localhost:8081",
      "auth": false
    }
  ],
  "log": {
    "level": "INFO"
  }
}